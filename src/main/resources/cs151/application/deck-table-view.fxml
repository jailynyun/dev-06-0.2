<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.DeckTableController"
      spacing="15"
      alignment="CENTER">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="All Stored Decks"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <TableView fx:id="deckTable" prefWidth="700" prefHeight="350">
        <columns>
            <TableColumn fx:id="nameColumn" text="Deck Name" prefWidth="200" />
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="480" />
        </columns>
    </TableView>

    <Button text="Add Flashcard"
        onAction="#onAddFlashcardClicked"/>

    <Button text="View Flashcards"
            onAction="#onViewFlashcardsClicked"/>

    <Button text="Back"
            onAction="#onBackClicked" />
</VBox>
