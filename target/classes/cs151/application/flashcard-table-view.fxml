<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.FlashcardTableController"
      alignment="CENTER"
      spacing="15">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="All Stored Flashcards"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <TableView fx:id="flashcardTable" prefWidth="900" prefHeight="400">
        <columns>
            <TableColumn fx:id="deckColumn" text="Deck" prefWidth="150"/>
            <TableColumn fx:id="questionColumn" text="Question" prefWidth="250"/>
            <TableColumn fx:id="answerColumn" text="Answer" prefWidth="250"/>
            <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="230"/>
        </columns>
    </TableView>

    <Button text="Back"
            onAction="#onBackClicked"/>
</VBox>