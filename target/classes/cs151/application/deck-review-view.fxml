<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.DeckReviewController"
      spacing="12" alignment="TOP_CENTER">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Deck Review" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Deck:" style="-fx-font-weight: bold;"/>
        <Label fx:id="deckNameLabel"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Filter:"/>
        <ComboBox fx:id="filterCombo" prefWidth="160"/>
    </HBox>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="80"/>
        </columnConstraints>

        <Label text="Front:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextArea fx:id="frontArea" wrapText="true" prefRowCount="4"
                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Back:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="backArea" wrapText="true" prefRowCount="4"
                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statusCombo" prefWidth="200"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Created At:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="createdAtLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Last Reviewed:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="lastReviewedLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="prevBtn" text="Previous" onAction="#onPrevClicked"/>
        <Button fx:id="nextBtn" text="Next" onAction="#onNextClicked"/>
        <Button text="Save" onAction="#onSaveClicked"/>
        <Button text="Cancel / Back" onAction="#onBackClicked"/>
    </HBox>
</VBox>
