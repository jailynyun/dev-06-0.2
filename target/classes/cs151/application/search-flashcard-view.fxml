<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cs151.application.SearchFlashcardController"
    spacing="12" alignment="TOP_CENTER">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Search Flashcards" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="searchField" promptText="Type to search (Deck / Front / Back / Status)..." prefWidth="420"/>
        <Button text="Search" onAction="#onSearchClicked"/>
    </HBox>

    <TableView fx:id="table" prefHeight="360" prefWidth="700">
        <columns>
            <TableColumn fx:id="deckCol" text="Deck" prefWidth="160"/>
            <TableColumn fx:id="frontCol" text="Front (1st line)" prefWidth="170"/>
            <TableColumn fx:id="backCol" text="Back (1st line)" prefWidth="170"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="90"/>
            <TableColumn fx:id="createdCol" text="Created At" prefWidth="160"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Delete Selected" onAction="#onDeleteClicked"/>
        <Button text="Back" onAction="#onBackClicked"/>
    </HBox>

</VBox>
