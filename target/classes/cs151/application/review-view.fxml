<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.ReviewController"
      spacing="12" alignment="TOP_CENTER">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <Label text="Review Decks" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="searchField" promptText="Search Deck..." prefWidth="420"/>
        <Button text="Search" onAction="#onSearchClicked"/>
    </HBox>

    <TableView fx:id="deckTable" prefWidth="720" prefHeight="360">
        <columns>
            <TableColumn fx:id="nameCol" text="Deck Name" prefWidth="240"/>
            <TableColumn fx:id="descCol" text="Description (1st line)" prefWidth="480"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Open Selected Deck" onAction="#onOpenClicked"/>
        <Button text="Back" onAction="#onBackClicked"/>
    </HBox>

</VBox>
