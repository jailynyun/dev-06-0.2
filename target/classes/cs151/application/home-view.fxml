<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.HomeController"
      spacing="18"
      alignment="CENTER"
      style="-fx-background-color: #111827;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="FlashCards System"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label text="Welcome! What would you like to do?"
           style="-fx-font-size: 16px; -fx-text-fill: #cbd5e1;"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="Study"
                onAction="#onStudyClicked"
                style="-fx-font-size: 14px; -fx-padding: 10 18;"/>

        <Button text="Manage Decks"
                onAction="#onManageDecksClicked"
                style="-fx-font-size: 14px; -fx-padding: 10 18;"/>

        <Button text="Add Deck"
                onAction="#onAddDecksClicked"
                style="-fx-font-size: 14px; -fx-padding: 10 18;"/>

        <Button text="Search Flashcards"
                onAction="#onSearchFlashcardsClicked"
                style="-fx-font-size: 14px; -fx-padding: 10 18;"/>

        <Button text="Quit"
                onAction="#onQuitClicked"
                style="-fx-font-size: 14px; -fx-padding: 10 18;"/>
    </HBox>

</VBox>
