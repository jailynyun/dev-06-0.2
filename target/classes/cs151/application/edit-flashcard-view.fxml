<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cs151.application.EditFlashcardController"
      spacing="10" alignment="CENTER">

    <Label text="Edit Flashcard" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <ComboBox fx:id="deckCombo"/>
    <ComboBox fx:id="statusCombo"/>

    <TextArea fx:id="frontArea" prefWidth="450" prefRowCount="4" wrapText="true" promptText="Front"/>
    <TextArea fx:id="backArea"  prefWidth="450" prefRowCount="4" wrapText="true" promptText="Back"/>

    <HBox spacing="10">
        <Button text="Save" onAction="#onSaveClicked"/>
        <Button text="Back" onAction="#onBackClicked"/>
    </HBox>
</VBox>
